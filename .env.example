# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git — it's already in .gitignore.

# Your deployed site URL (no trailing slash). Used in metadata and resume page.
NEXT_PUBLIC_SITE_URL=https://rubayethassan.com

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# Leave empty or remove entirely to disable analytics — no script ships without this.
NEXT_PUBLIC_GA_ID=
